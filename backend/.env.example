GIGACHAT_CREDENTIALS=
TAVILY_API_KEY=
# Local Docker: http://localhost:11434 (see docker-compose.yml)
# Remote LAN host: http://<host-ip>:11434 (OLLAMA_HOST=0.0.0.0 on that machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_VISION_FALLBACK_MODELS=llava:7b,moondream:latest
OLLAMA_TEXT_MODEL=qwen2.5:7b
DATABASE_URL=sqlite:///./data/moodroute.db
CHROMA_PATH=./data/chroma
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
